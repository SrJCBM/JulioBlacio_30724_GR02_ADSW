@startuml
title Arquitectura por Capas - IronClad Box (MVP implementado)\nMVC + Patron Builder

left to right direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial
skinparam linetype ortho

skinparam rectangle {
  RoundCorner 12
}

actor "Administrador" as Admin
actor "Entrenador" as Trainer
actor "Atleta" as Athlete

package "Capa de Presentacion\n(View - HTML + Vanilla JS)" #E3F2FD {
  rectangle "Vistas Administrador\ngestion_clases\ngestion_membresias\ngestion_usuarios\nreportes_admin" as AdminView
  rectangle "Vistas Entrenador\nseguimiento_progreso\ncomunicacion_entrenador" as TrainerView
  rectangle "Vistas Atleta\nreservas_atleta\nmembresia_atleta\nprogreso_atleta\nbandeja_atleta" as AthleteView
}

package "Capa Controladora\n(Controller - PHP)" #FFF3E0 {
  rectangle "ClaseController" as ClaseController
  rectangle "MembresiaController" as MembresiaController
  rectangle "UsuarioController" as UsuarioController
  rectangle "ProgresoController" as ProgresoController
  rectangle "ComunicacionController" as ComunicacionController
  rectangle "ReporteController" as ReporteController
}

package "Capa de Logica de Negocio\n(Service + Builder)" #E8F5E9 {
  rectangle "ClaseService\nHorarios, cupos,\nentrenadores e\ninscripciones" as ClaseService
  rectangle "MembresiaService\nMembresias, pagos\ny vencimientos" as MembresiaService
  rectangle "UsuarioService\nCuentas, roles\ny estado" as UsuarioService
  rectangle "ProgresoService\nResultados WOD\ne historial" as ProgresoService
  rectangle "ComunicacionService\nMensajes y\nanuncios" as ComunicacionService
  rectangle "ReporteService\nReportes de\nfinanzas y asistencia" as ReporteService

  rectangle "ClaseBuilder\n<<Builder>>\ndia, hora, duracion,\ncupo, entrenador" as ClaseBuilder #F3E5F5
  rectangle "MembresiaBuilder\n<<Builder>>\ntipo, precio, estado,\nfechas" as MembresiaBuilder #F3E5F5
  rectangle "UsuarioBuilder\n<<Builder>>\nnombre, email, rol,\nestado, hash" as UsuarioBuilder #F3E5F5
  rectangle "RegistroProgresoBuilder\n<<Builder>>\nWOD, tiempo, peso,\nrepeticiones" as ProgresoBuilder #F3E5F5
  rectangle "ReporteBuilder\n<<Builder>>\nfiltros, datos,\nformato y resumen" as ReporteBuilder #F3E5F5
}

package "Capa de Acceso a Datos\n(DAO - PDO)" #FCE4EC {
  rectangle "ClaseDAO" as ClaseDAO
  rectangle "MembresiaDAO" as MembresiaDAO
  rectangle "UsuarioDAO" as UsuarioDAO
  rectangle "ProgresoDAO" as ProgresoDAO
  rectangle "ComunicacionDAO" as ComunicacionDAO
  rectangle "ReporteDAO" as ReporteDAO
}

database "Base de Datos\nMySQL" #E0E0E0 {
  rectangle "usuarios" as TUsuarios
  rectangle "clases" as TClases
  rectangle "membresias" as TMembresias
  rectangle "reservas" as TReservas
  rectangle "progreso_atletas" as TProgreso
  rectangle "mensajes" as TMensajes
  rectangle "reportes" as TReportes
  rectangle "atletas / entrenadores" as TPersonas
}

Admin --> AdminView
Trainer --> TrainerView
Athlete --> AthleteView

AdminView --> ClaseController
AdminView --> MembresiaController
AdminView --> UsuarioController
AdminView --> ReporteController

TrainerView --> ProgresoController
TrainerView --> ComunicacionController

AthleteView --> ClaseController
AthleteView --> MembresiaController
AthleteView --> ProgresoController
AthleteView --> ComunicacionController

ClaseController --> ClaseService
MembresiaController --> MembresiaService
UsuarioController --> UsuarioService
ProgresoController --> ProgresoService
ComunicacionController --> ComunicacionService
ReporteController --> ReporteService

ClaseService --> ClaseBuilder : construye / retorna Clase
MembresiaService --> MembresiaBuilder : construye / retorna Membresia
UsuarioService --> UsuarioBuilder : construye / retorna Usuario
ProgresoService --> ProgresoBuilder : construye / retorna RegistroProgreso
ReporteService --> ReporteBuilder : formatea / retorna Reporte

ClaseService --> ClaseDAO
MembresiaService --> MembresiaDAO
UsuarioService --> UsuarioDAO
ProgresoService --> ProgresoDAO
ComunicacionService --> ComunicacionDAO
ReporteService --> ReporteDAO

' Validacion cruzada real: una reserva exige membresia vigente
ClaseService ..> MembresiaDAO : valida membresia\nvigente (reservas)

ClaseDAO --> TClases
ClaseDAO --> TReservas
ClaseDAO --> TPersonas
MembresiaDAO --> TMembresias
MembresiaDAO --> TPersonas
UsuarioDAO --> TUsuarios
ProgresoDAO --> TProgreso
ComunicacionDAO --> TMensajes
ReporteDAO --> TReportes

note bottom of ComunicacionService
  ComunicacionService NO usa Builder:
  el Mensaje es una entidad simple,
  se construye directo y se persiste.
end note

legend right
|= Color |= Significado |
|<#E3F2FD>| Capa de Presentacion (HTML + Vanilla JS) |
|<#FFF3E0>| Capa Controladora (PHP) |
|<#E8F5E9>| Logica de Negocio (Service) |
|<#F3E5F5>| Patron Builder |
|<#FCE4EC>| Acceso a Datos (DAO + PDO) |
|<#E0E0E0>| Base de Datos |
endlegend

@enduml
